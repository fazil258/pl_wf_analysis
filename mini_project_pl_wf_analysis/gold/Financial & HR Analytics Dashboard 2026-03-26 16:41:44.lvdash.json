{
  "datasets": [
    {
      "name": "37676754",
      "displayName": "Monthly Consolidated Revenue",
      "queryLines": [
        "SELECT\n",
        "  gl.fiscal_year,\n",
        "  gl.fiscal_period,\n",
        "  c.company_name,\n",
        "  SUM(gl.credit_amount) as revenue\n",
        "FROM\n",
        "  bronze_catalog.raw.general_ledgers gl\n",
        "    JOIN gold_catalog.mart.dim_account a\n",
        "      ON gl.account_id = a.account_id\n",
        "    JOIN gold_catalog.mart.dim_company c\n",
        "      ON gl.company_id = c.company_id\n",
        "WHERE\n",
        "  a.pl_section = 'Revenue'\n",
        "GROUP BY\n",
        "  gl.fiscal_year,\n",
        "  gl.fiscal_period,\n",
        "  c.company_name"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "e1ad36fd",
      "displayName": "Cost of Sales by Month",
      "queryLines": [
        "SELECT\n",
        "  gl.fiscal_year,\n",
        "  gl.fiscal_period,\n",
        "  c.company_name,\n",
        "  ROUND(SUM(gl.debit_amount), 2) AS cost_of_sales\n",
        "FROM\n",
        "  bronze_catalog.raw.general_ledgers gl\n",
        "    JOIN gold_catalog.mart.dim_account a\n",
        "      ON gl.account_id = a.account_id\n",
        "    JOIN gold_catalog.mart.dim_company c\n",
        "      ON gl.company_id = c.company_id\n",
        "WHERE\n",
        "  a.pl_section = 'COGS'\n",
        "GROUP BY\n",
        "  gl.fiscal_year,\n",
        "  gl.fiscal_period,\n",
        "  c.company_name\n",
        "ORDER BY\n",
        "  gl.fiscal_year,\n",
        "  gl.fiscal_period,\n",
        "  c.company_name"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "78ad4cce",
      "displayName": "Gross Profit by Month",
      "queryLines": [
        "WITH revenue AS (\n",
        "  SELECT\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name,\n",
        "    SUM(gl.credit_amount) as revenue_amount\n",
        "  FROM\n",
        "    bronze_catalog.raw.general_ledgers gl\n",
        "      JOIN gold_catalog.mart.dim_account a\n",
        "        ON gl.account_id = a.account_id\n",
        "      JOIN gold_catalog.mart.dim_company c\n",
        "        ON gl.company_id = c.company_id\n",
        "  WHERE\n",
        "    a.pl_section = 'Revenue'\n",
        "  GROUP BY\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name\n",
        "),\n",
        "cogs AS (\n",
        "  SELECT\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name,\n",
        "    SUM(gl.debit_amount) as cogs_amount\n",
        "  FROM\n",
        "    bronze_catalog.raw.general_ledgers gl\n",
        "      JOIN gold_catalog.mart.dim_account a\n",
        "        ON gl.account_id = a.account_id\n",
        "      JOIN gold_catalog.mart.dim_company c\n",
        "        ON gl.company_id = c.company_id\n",
        "  WHERE\n",
        "    a.pl_section = 'Cost of Sales'\n",
        "  GROUP BY\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name\n",
        ")\n",
        "SELECT\n",
        "  r.fiscal_year,\n",
        "  r.fiscal_period,\n",
        "  r.company_name,\n",
        "  r.revenue_amount,\n",
        "  COALESCE(c.cogs_amount, 0) as cogs_amount,\n",
        "  r.revenue_amount - COALESCE(c.cogs_amount, 0) as gross_profit\n",
        "FROM\n",
        "  revenue r\n",
        "    LEFT JOIN cogs c\n",
        "      ON r.fiscal_year = c.fiscal_year\n",
        "      AND r.fiscal_period = c.fiscal_period\n",
        "      AND r.company_name = c.company_name"
      ],
      "columns": [
        {
          "displayName": "Gross Profit Margin %",
          "description": "Profitability percentage after deducting cost of sales from revenue",
          "expression": "(`gross_profit` / `revenue_amount`) * 100"
        }
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "96b6ddc4",
      "displayName": "Net Profit by Month",
      "queryLines": [
        "WITH revenue AS (\n",
        "  SELECT\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name,\n",
        "    SUM(gl.credit_amount) as amount\n",
        "  FROM\n",
        "    bronze_catalog.raw.general_ledgers gl\n",
        "      JOIN gold_catalog.mart.dim_account a\n",
        "        ON gl.account_id = a.account_id\n",
        "      JOIN gold_catalog.mart.dim_company c\n",
        "        ON gl.company_id = c.company_id\n",
        "  WHERE\n",
        "    a.pl_section = 'Revenue'\n",
        "  GROUP BY\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name\n",
        "),\n",
        "expenses AS (\n",
        "  SELECT\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name,\n",
        "    SUM(gl.debit_amount) as amount\n",
        "  FROM\n",
        "    bronze_catalog.raw.general_ledgers gl\n",
        "      JOIN gold_catalog.mart.dim_account a\n",
        "        ON gl.account_id = a.account_id\n",
        "      JOIN gold_catalog.mart.dim_company c\n",
        "        ON gl.company_id = c.company_id\n",
        "  WHERE\n",
        "    a.pl_section IN ('Cost of Sales', 'Operating Expense')\n",
        "  GROUP BY\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name\n",
        ")\n",
        "SELECT\n",
        "  r.fiscal_year,\n",
        "  r.fiscal_period,\n",
        "  r.company_name,\n",
        "  r.amount as revenue,\n",
        "  COALESCE(e.amount, 0) as total_expenses,\n",
        "  r.amount - COALESCE(e.amount, 0) as net_profit\n",
        "FROM\n",
        "  revenue r\n",
        "    LEFT JOIN expenses e\n",
        "      ON r.fiscal_year = e.fiscal_year\n",
        "      AND r.fiscal_period = e.fiscal_period\n",
        "      AND r.company_name = e.company_name"
      ]
    },
    {
      "name": "bea4049b",
      "displayName": "Operating Expense Breakdown",
      "queryLines": [
        "SELECT\n",
        "  gl.fiscal_year,\n",
        "  gl.fiscal_period,\n",
        "  c.company_name,\n",
        "  a.opex_category,\n",
        "  a.account_name,\n",
        "  SUM(gl.debit_amount) as expense_amount\n",
        "FROM\n",
        "  bronze_catalog.raw.general_ledgers gl\n",
        "    JOIN gold_catalog.mart.dim_account a\n",
        "      ON gl.account_id = a.account_id\n",
        "    JOIN gold_catalog.mart.dim_company c\n",
        "      ON gl.company_id = c.company_id\n",
        "WHERE\n",
        "  a.pl_section = 'Operating Expense'\n",
        "GROUP BY\n",
        "  gl.fiscal_year,\n",
        "  gl.fiscal_period,\n",
        "  c.company_name,\n",
        "  a.opex_category,\n",
        "  a.account_name"
      ]
    },
    {
      "name": "cb7e58f0",
      "displayName": "Average Compensation by Position",
      "queryLines": [
        "SELECT\n",
        "  e.position,\n",
        "  c.company_name,\n",
        "  AVG(p.total_compensation) as avg_total_compensation,\n",
        "  AVG(p.gross_salary) as avg_base_salary,\n",
        "  AVG(p.bonus) as avg_bonus,\n",
        "  AVG(p.overtime_pay) as avg_overtime,\n",
        "  AVG(p.commission) as avg_commission,\n",
        "  COUNT(DISTINCT e.employee_id) as employee_count\n",
        "FROM\n",
        "  gold_catalog.mart.fact_payroll p\n",
        "    JOIN bronze_catalog.raw.employee e\n",
        "      ON p.employee_id = e.employee_id\n",
        "    JOIN gold_catalog.mart.dim_company c\n",
        "      ON p.company_id = c.company_id\n",
        "GROUP BY\n",
        "  e.position,\n",
        "  c.company_name"
      ]
    },
    {
      "name": "677f7707",
      "displayName": "Overtime and Bonus Analysis",
      "queryLines": [
        "SELECT\n",
        "  d.department_name,\n",
        "  c.company_name,\n",
        "  p.fiscal_year,\n",
        "  p.fiscal_period,\n",
        "  SUM(p.overtime_pay) as total_overtime,\n",
        "  SUM(p.bonus) as total_bonus,\n",
        "  SUM(p.gross_salary) as total_base_salary,\n",
        "  COUNT(DISTINCT p.employee_id) as employee_count\n",
        "FROM\n",
        "  gold_catalog.mart.fact_payroll p\n",
        "    JOIN gold_catalog.mart.dim_departments d\n",
        "      ON p.department_id = d.department_id\n",
        "    JOIN gold_catalog.mart.dim_company c\n",
        "      ON p.company_id = c.company_id\n",
        "GROUP BY\n",
        "  d.department_name,\n",
        "  c.company_name,\n",
        "  p.fiscal_year,\n",
        "  p.fiscal_period"
      ],
      "columns": [
        {
          "displayName": "Overtime to Base Ratio %",
          "description": "Overtime pay as percentage of base salary showing variable compensation intensity",
          "expression": "(`total_overtime` / `total_base_salary`) * 100"
        }
      ]
    },
    {
      "name": "7e028749",
      "displayName": "Cost per Department",
      "queryLines": [
        "SELECT\n",
        "  d.department_name,\n",
        "  c.company_name,\n",
        "  p.fiscal_year,\n",
        "  p.fiscal_period,\n",
        "  SUM(p.total_compensation) as total_payroll_cost,\n",
        "  COUNT(DISTINCT p.employee_id) as employee_count\n",
        "FROM\n",
        "  gold_catalog.mart.fact_payroll p\n",
        "    JOIN gold_catalog.mart.dim_departments d\n",
        "      ON p.department_id = d.department_id\n",
        "    JOIN gold_catalog.mart.dim_company c\n",
        "      ON p.company_id = c.company_id\n",
        "GROUP BY\n",
        "  d.department_name,\n",
        "  c.company_name,\n",
        "  p.fiscal_year,\n",
        "  p.fiscal_period"
      ]
    },
    {
      "name": "c97b5486",
      "displayName": "Headcount Distribution",
      "queryLines": [
        "SELECT\n",
        "  d.department_name,\n",
        "  c.company_name,\n",
        "  COUNT(DISTINCT e.employee_id) as active_headcount\n",
        "FROM\n",
        "  bronze_catalog.raw.employee e\n",
        "    JOIN gold_catalog.mart.dim_departments d\n",
        "      ON e.department_id = d.department_id\n",
        "    JOIN gold_catalog.mart.dim_company c\n",
        "      ON e.company_id = c.company_id\n",
        "WHERE\n",
        "  e.is_active = true\n",
        "GROUP BY\n",
        "  d.department_name,\n",
        "  c.company_name"
      ]
    },
    {
      "name": "dbaad6c6",
      "displayName": "Payroll Cost as % of Revenue",
      "queryLines": [
        "WITH payroll_costs AS (\n",
        "  SELECT\n",
        "    p.fiscal_year,\n",
        "    p.fiscal_period,\n",
        "    c.company_name,\n",
        "    SUM(p.total_compensation) as total_payroll\n",
        "  FROM\n",
        "    gold_catalog.mart.fact_payroll p\n",
        "      JOIN gold_catalog.mart.dim_company c\n",
        "        ON p.company_id = c.company_id\n",
        "  GROUP BY\n",
        "    p.fiscal_year,\n",
        "    p.fiscal_period,\n",
        "    c.company_name\n",
        "),\n",
        "revenue AS (\n",
        "  SELECT\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name,\n",
        "    SUM(gl.credit_amount) as total_revenue\n",
        "  FROM\n",
        "    bronze_catalog.raw.general_ledgers gl\n",
        "      JOIN gold_catalog.mart.dim_account a\n",
        "        ON gl.account_id = a.account_id\n",
        "      JOIN gold_catalog.mart.dim_company c\n",
        "        ON gl.company_id = c.company_id\n",
        "  WHERE\n",
        "    a.pl_section = 'Revenue'\n",
        "  GROUP BY\n",
        "    gl.fiscal_year,\n",
        "    gl.fiscal_period,\n",
        "    c.company_name\n",
        ")\n",
        "SELECT\n",
        "  p.fiscal_year,\n",
        "  p.fiscal_period,\n",
        "  p.company_name,\n",
        "  p.total_payroll,\n",
        "  r.total_revenue\n",
        "FROM\n",
        "  payroll_costs p\n",
        "    JOIN revenue r\n",
        "      ON p.fiscal_year = r.fiscal_year\n",
        "      AND p.fiscal_period = r.fiscal_period\n",
        "      AND p.company_name = r.company_name"
      ],
      "columns": [
        {
          "displayName": "Payroll as % of Revenue",
          "description": "Labor efficiency ratio showing payroll costs as percentage of revenue",
          "expression": "(`total_payroll` / `total_revenue`) * 100"
        }
      ]
    },
    {
      "name": "1caf8a9d",
      "displayName": "Monthly Revenue Insights from Consolidated Data",
      "queryLines": [
        "select * from gold_catalog.mart.kpi1_monthly_consolidated_revenue"
      ]
    }
  ],
